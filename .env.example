
# PostgreSQL
POSTGRES_USER=datauser
POSTGRES_PASSWORD=datapass123
POSTGRES_DB=data_platform
POSTGRES_URL=postgresql://datauser:datapass123@localhost:5432/data_platform

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_WEATHER=weather-events
KAFKA_TOPIC_CRYPTO=crypto-events

# External APIs (free, no key needed for these)
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
CRYPTO_API_URL=https://api.coingecko.com/api/v3

# Airflow
AIRFLOW_FERNET_KEY=your-generated-fernet-key-here

# App settings
LOG_LEVEL=INFO
ENVIRONMENT=development